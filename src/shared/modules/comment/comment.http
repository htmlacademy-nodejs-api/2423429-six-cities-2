### ========================================
### 3. GET ALL COMMENTS FOR OFFER (public - no auth required)
### ========================================
GET {{baseUrl}}/offers/694423a789d72214ee02a24a/comments

###

### ========================================
### 4. CREATE NEW COMMENT (requires authorization)
### ========================================
POST {{baseUrl}}/offers/694423a789d72214ee02a24a/comments
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "text": "Great apartment! Very clean and cozy. Highly recommended!",
  "rating": 5
}

###

### ========================================
### 5. CREATE ANOTHER COMMENT FOR DIFFERENT OFFER
### ========================================
POST {{baseUrl}}/offers/694423a789d72214ee02a252/comments
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "text": "Nice place, clean and comfortable. Shops and transport nearby.",
  "rating": 4
}

###

### ========================================
### 6. CREATE COMMENT WITH MINIMAL TEXT LENGTH (should return 400)
### ========================================
POST {{baseUrl}}/offers/694423a789d72214ee02a24a/comments
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "text": "Ok",
  "rating": 5
}

###

### ========================================
### 7. CREATE COMMENT WITH INVALID RATING (should return 400)
### ========================================
POST {{baseUrl}}/offers/694423a789d72214ee02a24a/comments
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "text": "Good place but has some issues",
  "rating": 10
}

###

### ========================================
### 8. CREATE COMMENT WITHOUT TOKEN (should return 401)
### ========================================
POST {{baseUrl}}/offers/694423a789d72214ee02a24a/comments
Content-Type: application/json

{
  "text": "Test comment without token",
  "rating": 3
}

###

### ========================================
### 9. CREATE COMMENT WITHOUT REQUIRED FIELDS (should return 400)
### ========================================
POST {{baseUrl}}/offers/694423a789d72214ee02a24a/comments
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "text": "Only text"
}

###

### ========================================
### 10. GET COMMENTS FOR NON-EXISTENT OFFER (should return empty array)
### ========================================
GET {{baseUrl}}/offers/000000000000000000000000/comments

###

### ========================================
### 11. CREATE COMMENT FOR NON-EXISTENT OFFER (should return 404)
### ========================================
POST {{baseUrl}}/offers/000000000000000000000000/comments
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "text": "This offer does not exist",
  "rating": 3
}

###

### ========================================
### 12. INVALID OFFER ID FORMAT (should return 400)
### ========================================
GET {{baseUrl}}/offers/not-an-object-id/comments

###

### ========================================
### 13. GET COMMENTS AFTER ADDING (should return all comments)
### ========================================
GET {{baseUrl}}/offers/694423a789d72214ee02a24a/comments

###

### ========================================
### 14. CREATE COMMENT WITH MIN RATING (1)
### ========================================
POST {{baseUrl}}/offers/694423a789d72214ee02a24a/comments
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "text": "Did not like it, noisy and dirty",
  "rating": 1
}

###

### ========================================
### 15. CREATE COMMENT WITH MAX RATING (5)
### ========================================
POST {{baseUrl}}/offers/694423a789d72214ee02a24a/comments
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "text": "Excellent place, will come back again!",
  "rating": 5
}


### ========================================
### 3. CREATE NEW OFFER (requires authorization)
### ========================================
POST {{baseUrl}}/offers
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "title": "Cozy apartment in the center of Paris",
  "description": "Beautiful apartment with Eiffel Tower view. Fully furnished, all necessary appliances. Metro, cafes and shops nearby.",
  "city": "Paris",
  "previewImage": "apartment-1.jpg",
  "images": [
    "apartment-1.jpg",
    "apartment-2.jpg",
    "apartment-3.jpg",
    "apartment-4.jpg",
    "apartment-5.jpg",
    "apartment-6.jpg"
  ],
  "isPremium": true,
  "type": "apartment",
  "rooms": 2,
  "guests": 4,
  "price": 150,
  "goods": [
    "Breakfast",
    "Air conditioning",
    "Laptop",
    "friendly workspace",
    "Fridge"
  ],
  "host": "698deb8418032e5703fd15df",
  "location": {
    "latitude": 48.8566,
    "longitude": 2.3522
  }
}

###

### ========================================
### 4. GET ALL OFFERS (public)
### ========================================
GET {{baseUrl}}/offers

###

### ========================================
### 5. GET OFFER BY ID
### ========================================
GET {{baseUrl}}/offers/694423a789d72214ee02a245

###

### ========================================
### 6. GET PREMIUM OFFERS BY CITY
### ========================================
GET {{baseUrl}}/offers/premium/Paris

###

### ========================================
### 7. GET PREMIUM OFFERS WITH LIMIT
### ========================================
GET {{baseUrl}}/offers/premium/Paris?limit=5

###

### ========================================
### 8. GET FAVORITE OFFERS (requires authorization)
### ========================================
GET {{baseUrl}}/offers/favorites
Authorization: Bearer {{authToken}}

###

### ========================================
### 9. ADD OFFER TO FAVORITES (requires authorization)
### ========================================
POST {{baseUrl}}/offers/694423a789d72214ee02a245/favorite
Authorization: Bearer {{authToken}}

###

### ========================================
### 10. REMOVE OFFER FROM FAVORITES (requires authorization)
### ========================================
DELETE {{baseUrl}}/offers/694423a789d72214ee02a245/favorite
Authorization: Bearer {{authToken}}

###

### ========================================
### 11. UPDATE OFFER (requires authorization)
### ========================================
PATCH {{baseUrl}}/offers/694423a789d72214ee02a245
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "price": 180,
  "isPremium": false,
  "guests": 5
}

###

### ========================================
### 12. DELETE OFFER (requires authorization)
### ========================================
DELETE {{baseUrl}}/offers/694423a789d72214ee02a245
Authorization: Bearer {{authToken}}

###

### ========================================
### ERROR TESTS
### ========================================

### 13. CREATE OFFER WITHOUT TOKEN (should return 401)
POST {{baseUrl}}/offers
Content-Type: application/json

{
  "title": "Test offer",
  "description": "Test offer description",
  "city": "Paris",
  "previewImage": "apartment-1.jpg",
  "images": [
    "apartment-1.jpg",
    "apartment-2.jpg",
    "apartment-3.jpg",
    "apartment-4.jpg",
    "apartment-5.jpg",
    "apartment-6.jpg"
  ],
  "isPremium": false,
  "type": "apartment",
  "rooms": 2,
  "guests": 3,
  "price": 100,
  "goods": ["Breakfast"],
  "host": "698deb8418032e5703fd15df",
  "location": {
    "latitude": 48.8566,
    "longitude": 2.3522
  }
}

